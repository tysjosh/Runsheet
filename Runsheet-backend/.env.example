# =============================================================================
# Runsheet Backend — Environment Configuration Template
# =============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env.development:  cp .env.example .env.development
#   2. Replace all placeholder values (marked "your-*-here") with real credentials
#   3. NEVER commit .env.development or any file with real credentials
#
# The ENVIRONMENT variable determines which .env file is loaded at runtime.
# =============================================================================

# =============================================================================
# ENVIRONMENT (Required)
# =============================================================================
# Determines which environment-specific .env file to load.
# Valid values: development, staging, production
# Format: string
ENVIRONMENT=development

# =============================================================================
# ELASTICSEARCH CONFIGURATION (Required)
# =============================================================================
# Elasticsearch Cloud endpoint URL.
# Format: https://<deployment-name>.<region>.gcp.elastic.cloud:443
# Required: yes
ELASTIC_ENDPOINT=https://your-elasticsearch-endpoint.elastic-cloud.com

# Elasticsearch API key for authentication.
# Format: base64-encoded string (obtain from Elasticsearch Cloud console)
# Required: yes
ELASTIC_API_KEY=your-api-key-here

# =============================================================================
# GOOGLE CLOUD / GEMINI CONFIGURATION (Required)
# =============================================================================
# Google Cloud Platform project ID.
# Format: string, 6-30 characters
# Required: yes
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud region for Vertex AI.
# Format: GCP region string (e.g., us-central1, europe-west1)
# Required: yes (default: us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# Path to GCP service account credentials JSON file.
# Format: absolute file path
# Required: no (not needed if using `gcloud auth application-default login`)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# =============================================================================
# AUTHENTICATION / JWT CONFIGURATION (Required)
# =============================================================================
# Secret key for signing and verifying JWT tokens.
# Format: string, minimum 32 characters recommended
# Required: yes
JWT_SECRET=your-jwt-secret-here

# JWT signing algorithm.
# Format: string (HS256, HS384, HS512)
# Required: yes (default: HS256)
JWT_ALGORITHM=HS256

# =============================================================================
# SESSION STORE CONFIGURATION (Required)
# =============================================================================
# Session store backend type.
# Valid values: redis, dynamodb
# Required: yes (default: redis)
SESSION_STORE_TYPE=redis

# Redis connection URL.
# Format: redis://<host>:<port> or redis://:<password>@<host>:<port>
# Required: yes for redis session store in non-dev environments
#           (in development, falls back to in-memory store if not set)
# REDIS_URL=redis://localhost:6379

# DynamoDB table name for session storage.
# Format: string
# Required: only if SESSION_STORE_TYPE=dynamodb
# DYNAMODB_TABLE=runsheet-sessions

# Session time-to-live in hours.
# Format: integer, 1-168
# Required: no (default: 24)
SESSION_TTL_HOURS=24

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Maximum API requests per minute per IP.
# Format: integer, 1-10000
# Required: no (default: 100)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Maximum AI chat requests per minute per IP.
# Format: integer, 1-1000
# Required: no (default: 10)
RATE_LIMIT_AI_REQUESTS_PER_MINUTE=10

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================
# Application logging level.
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Required: no (default: INFO)
LOG_LEVEL=INFO

# OpenTelemetry collector endpoint for traces and metrics.
# Format: http://<host>:<port>
# Required: no (traces disabled if not set)
# OTEL_ENDPOINT=http://localhost:4317

# Service name for OpenTelemetry traces.
# Format: string
# Required: no (default: runsheet-backend)
OTEL_SERVICE_NAME=runsheet-backend

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed CORS origins.
# Format: JSON array of URL strings
# Required: yes
CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# DINEE / OPS INTELLIGENCE CONFIGURATION
# =============================================================================
# HMAC-SHA256 shared secret for verifying inbound Dinee webhooks.
# This is the sole webhook authentication credential.
# Format: string, minimum 32 characters recommended
# Required: yes in non-development environments
DINEE_WEBHOOK_SECRET=your-webhook-secret-here

# Tenant ID associated with the webhook signing secret.
# When set, rejects payloads whose tenant_id does not match.
# Format: string (UUID or tenant identifier)
# Required: no
# DINEE_WEBHOOK_TENANT_ID=your-tenant-id

# Idempotency store TTL in hours.
# Format: integer, 1-720
# Required: no (default: 72)
DINEE_IDEMPOTENCY_TTL_HOURS=72

# Dinee REST API base URL for Replay Service backfill.
# Format: https://<host>
# Required: no (replay disabled if not set)
# DINEE_API_BASE_URL=https://api.dinee.example.com

# Dinee API key for outbound Replay Service REST calls only.
# NOT used for webhook authentication.
# Format: string
# Required: no
# DINEE_API_KEY=your-dinee-api-key-here

# =============================================================================
# OPS RATE LIMITING CONFIGURATION
# =============================================================================
# Webhook rate limit per minute per IP.
# Format: integer, 1-10000
# Required: no (default: 500)
OPS_WEBHOOK_RATE_LIMIT=500

# Ops API rate limit per minute per user.
# Format: integer, 1-10000
# Required: no (default: 100)
OPS_API_RATE_LIMIT=100

# Metrics API rate limit per minute per user.
# Format: integer, 1-1000
# Required: no (default: 20)
OPS_METRICS_RATE_LIMIT=20

# =============================================================================
# FUEL MONITORING CONFIGURATION
# =============================================================================
# Default low-stock alert threshold percentage for fuel stations.
# Format: float, 0-100
# Required: no (default: 20.0)
FUEL_ALERT_DEFAULT_THRESHOLD_PCT=20.0

# Rolling window in days for daily consumption rate calculation.
# Format: integer, 1-365
# Required: no (default: 7)
FUEL_CONSUMPTION_ROLLING_WINDOW_DAYS=7

# Days until empty below which alert escalates to critical.
# Format: integer, 1-30
# Required: no (default: 3)
FUEL_CRITICAL_DAYS_THRESHOLD=3

# =============================================================================
# SCHEDULING CONFIGURATION
# =============================================================================
# Default ETA hours when no route calculation is available.
# Format: integer
# Required: no (default: 4)
SCHEDULING_DEFAULT_ETA_HOURS=4

# Interval in seconds for periodic delay detection check.
# Format: integer
# Required: no (default: 60)
SCHEDULING_DELAY_CHECK_INTERVAL_SECONDS=60

# Maximum concurrent active jobs per asset.
# Format: integer
# Required: no (default: 1)
SCHEDULING_MAX_ACTIVE_JOBS_PER_ASSET=1
