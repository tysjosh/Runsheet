# =============================================================================
# .gitignore — Runsheet Logistics Platform
# =============================================================================
# Organized into clearly labeled sections per Requirement 13.1.
# IMPORTANT: .env.example, .coveragerc, and pytest.ini must remain tracked.
# =============================================================================

# =============================================================================
# Python
# =============================================================================
*.pyc
*.pyo
*.pyd
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/
dist/
build/
develop-eggs/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
.installed.cfg
MANIFEST
.Python

# =============================================================================
# Virtual Environments
# =============================================================================
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# =============================================================================
# Node.js / Next.js
# =============================================================================
node_modules/
.next/
out/
.swc/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
jspm_packages/
.npm
.eslintcache
*.tsbuildinfo
.yarn-integrity
*.tgz
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.node_repl_history
.cache
.parcel-cache
.pnp.*

# Frontend-specific build artifacts
runsheet/.next/
runsheet/out/
runsheet/.swc/

# =============================================================================
# Testing / Coverage
# =============================================================================
.coverage
htmlcov/
coverage_html/
coverage/
.hypothesis/
.pytest_cache/
test-results/
playwright-report/
*.lcov
.nyc_output

# Backend-specific test artifacts
Runsheet-backend/.hypothesis/
Runsheet-backend/coverage_html/

# Frontend-specific test artifacts
runsheet/coverage/
runsheet/test-results/
runsheet/playwright-report/

# =============================================================================
# Environment
# =============================================================================
# Generic env files
.env
.env.local

# Environment-specific files containing real credentials
.env.development
.env.staging
.env.production

# Frontend environment files
runsheet/.env.local

# NOTE: .env.example files must remain tracked — do NOT add .env.example here.

# =============================================================================
# Kiro
# =============================================================================
.kiro/

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sw?
*~
*.suo
*.ntvs*
*.njsproj
*.sln
.vscode-test

# =============================================================================
# OS Generated Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Build Artifacts
# =============================================================================
# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Database files
*.db
*.sqlite
*.sqlite3

# Temporary folders
tmp/
temp/

# Google Cloud credentials
ascendant-woods-*.json
**/ascendant-woods-*.json

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Deployment / Hosting
.netlify
.vercel

# Yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# =============================================================================
# Negation Rules — Ensure tracked config templates are NOT excluded
# =============================================================================
!.env.example
!*/.env.example
!**/.env.example
!.coveragerc
!*/.coveragerc
!**/.coveragerc
!pytest.ini
!**/pytest.ini
